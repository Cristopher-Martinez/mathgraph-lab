generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "sqlite"
    url      = env("DATABASE_URL")
}

model User {
    id        Int      @id @default(autoincrement())
    username  String   @unique
    password  String
    createdAt DateTime @default(now())
}

model Topic {
    id               Int        @id @default(autoincrement())
    name             String     @unique
    createdByClassId Int?
    createdAt        DateTime   @default(now())
    exercises        Exercise[]
    formulas         Formula[]
    progress         Progress[]
    doc              TopicDoc?
}

model Formula {
    id          Int    @id @default(autoincrement())
    topicId     Int
    latex       String
    explanation String
    topic       Topic  @relation(fields: [topicId], references: [id])
}

model Exercise {
    id                 Int          @id @default(autoincrement())
    topicId            Int
    latex              String
    difficulty         String
    generatedByClassId Int?
    topic              Topic        @relation(fields: [topicId], references: [id])
    createdAt          DateTime     @default(now())
    hints              String?
    steps              String?
    socratic           String?
    tip                ExerciseTip?
    reviews            ExerciseReview[]
}

model Progress {
    id        Int      @id @default(autoincrement())
    topicId   Int
    completed Boolean  @default(false)
    score     Float?
    updatedAt DateTime @updatedAt
    topic     Topic    @relation(fields: [topicId], references: [id])
}

model AIInteraction {
    id        Int      @id @default(autoincrement())
    prompt    String
    response  String
    createdAt DateTime @default(now())
}

model ClassLog {
    id              Int          @id @default(autoincrement())
    date            DateTime
    title           String?
    transcript      String
    transcriptHash  String?
    summary         String?
    topics          String?
    formulas        String?
    activities      String?
    createdAt       DateTime     @default(now())
    images          ClassImage[]
    chunks          ClassChunk[]
    notes           ClassNote[]

    // Vectorización (Fase 1)
    vectorized      Boolean      @default(false)
    vectorizedAt    DateTime?

    // Análisis (Fase 2: Flash preview)
    analyzed        Boolean      @default(false)
    analyzedAt      DateTime?
    analysisModel   String?      // "flash-preview" | "pro"

    // Fuente de verdad (Fase 3: Pro)
    deepAnalyzed    Boolean      @default(false)
    deepAnalyzedAt  DateTime?

    @@index([transcriptHash, createdAt])
}

model ClassImage {
    id       Int      @id @default(autoincrement())
    classId  Int
    url      String
    caption  String?
    classLog ClassLog @relation(fields: [classId], references: [id])
}

model TopicDependency {
    id                 Int  @id @default(autoincrement())
    parentId           Int
    childId            Int
    generatedByClassId Int?

    @@unique([parentId, childId])
}

model ClassChunk {
    id        Int      @id @default(autoincrement())
    classId   Int
    text      String
    embedding String
    index     Int
    classLog  ClassLog @relation(fields: [classId], references: [id], onDelete: Cascade)

    @@index([classId])
}

model ClassNote {
    id        Int      @id @default(autoincrement())
    classId   Int
    titulo    String
    contenido String
    categoria String
    classLog  ClassLog @relation(fields: [classId], references: [id], onDelete: Cascade)
    createdAt DateTime @default(now())

    @@index([classId])
}

model TopicDoc {
    id           Int      @id @default(autoincrement())
    topicId      Int      @unique
    conceptos    String
    ejemplos     String // JSON array
    casosDeUso   String // JSON array
    curiosidades String // JSON array
    createdAt    DateTime @default(now())
    topic        Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model ExerciseTip {
    id           Int      @id @default(autoincrement())
    exerciseId   Int      @unique
    tips         String // JSON array
    classContext String // JSON array
    createdAt    DateTime @default(now())
    exercise     Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
}

// ─── Spaced Repetition (SM-2) ───

model ExerciseReview {
    id          Int       @id @default(autoincrement())
    exerciseId  Int
    ease        Float     @default(2.5)
    interval    Int       @default(0) // días
    repetitions Int       @default(0)
    nextReview  DateTime
    lastReview  DateTime?
    lastScore   Float? // 0-5 (SM-2 scale)
    exercise    Exercise  @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

    @@unique([exerciseId])
    @@index([nextReview])
}

// ─── Chat Persistente ───

model ChatSession {
    id        Int           @id @default(autoincrement())
    title     String?
    createdAt DateTime      @default(now())
    updatedAt DateTime      @updatedAt
    messages  ChatMessage[]
}

model ChatMessage {
    id        Int         @id @default(autoincrement())
    sessionId Int
    role      String // "user" | "assistant"
    text      String
    images    String? // JSON array of image URLs/base64
    sources   String? // JSON array of RAG sources
    createdAt DateTime    @default(now())
    session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

    @@index([sessionId])
}

// ─── Análisis de Patrones de Error ───

model ErrorPattern {
    id           Int      @id @default(autoincrement())
    exerciseId   Int?
    topicId      Int?
    errorType    String // "signo", "operacion", "conceptual", "calculo", "notacion"
    description  String
    studentAnswer String
    expectedAnswer String?
    createdAt    DateTime @default(now())

    @@index([topicId])
    @@index([errorType])
}
